        given-names: "David"
    title: "Where are the hard knapsack problems?"
    journal: "Computers & Operations Research"
    volume: 32
    issue: 9
    start: 2271
    end: 2284
    year: 2005
    doi: "10.1016/j.cor.2004.03.002"
